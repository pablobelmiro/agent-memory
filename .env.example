OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

LLM_NUM_PREDICT=256        # máximo de tokens gerados por resposta
LLM_NUM_CTX=2048           # tamanho da context window
LLM_TEMPERATURE=0.7
LLM_NUM_THREAD=4           # threads de CPU para inferência

MEMORY_MAX_NOTES=20        # máximo de notas na camada 1
MEMORY_MAX_TOPICS=5        # máximo de tópicos carregados por turno
HISTORY_MAX_SEARCH=10      # máximo de resultados no grep do histórico

AGENT_MAX_HISTORY_TURNS=3  # turnos mantidos no contexto ativo
AGENT_MAX_ITERATIONS=10    # proteção contra loops infinitos